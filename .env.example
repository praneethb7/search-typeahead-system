# ============================================================================
# Search Typeahead — configuration. Copy to ".env" and tweak as needed.
#   cp .env.example .env       (PowerShell: Copy-Item .env.example .env)
# Every value below has a safe default in backend/config.py, so .env is optional.
# ============================================================================

# ---- Primary data store (SQLite) ----
DB_PATH=data/typeahead.db

# ---- Suggestion behaviour ----
SUGGEST_LIMIT=10            # max suggestions returned (assignment requires 10)

# ---- Distributed cache: 3 Redis nodes routed by consistent hashing ----
# Comma-separated logical_name|host|port entries.
CACHE_NODES=c0|localhost|6379,c1|localhost|6380,c2|localhost|6381
CACHE_TTL_SECONDS=30        # suggestion cache expiry (eviction)
RING_VNODES=150            # virtual nodes per physical node on the hash ring

# ---- Batch writes (write-reduction) ----
BATCH_MAX_SIZE=500         # flush when this many distinct queries are buffered
BATCH_INTERVAL_SECONDS=2   # ...or flush at least this often

# ---- Trending / recency-aware ranking ----
TRENDING_WINDOW_SECONDS=600   # sliding window length (10 min)
TRENDING_BUCKET_SECONDS=60    # bucket granularity (1 min)
TRENDING_HALFLIFE_SECONDS=300 # exponential decay half-life for recency score
RECENCY_WEIGHT=8.0            # how strongly recent activity boosts ranking
